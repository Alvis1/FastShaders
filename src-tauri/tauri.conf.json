{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FastShaders",
  "version": "../package.json",
  "identifier": "lv.alvismisjuns.fastshaders",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "FastShaders",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "resources": {
      "carousel-dist/": "ShaderCarousel/"
    },
    "category": "DeveloperTool",
    "shortDescription": "TSL visual shader editor",
    "longDescription": "FastShaders — bi-directional TSL (Three.js Shading Language) visual shader editor. Offline desktop build.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
