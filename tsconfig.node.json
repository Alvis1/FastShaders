{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "composite": true,
    "emitDeclarationOnly": true,
    // Park the declaration emit outside the tree. `composite` forces some emit,
    // and without an outDir it lands next to each source — fine when this project
    // was vite.config.ts alone (vite.config.d.ts is gitignored), but it would now
    // drop a stray .d.ts beside descriptionSplice.ts. Nothing consumes these.
    "outDir": "node_modules/.tmp/tsconfig-node",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true
  },
  // descriptionSplice is imported by vite.config.ts (the /__nd/descriptions
  // endpoint splices descriptions server-side), so this project must list it —
  // `tsc -b` errors TS6307 otherwise. It is deliberately DOM-free and app-import
  // free, which is what lets it compile under this project's ES2023-only lib as
  // well as the browser project's.
  "include": ["vite.config.ts", "src/registry/descriptionSplice.ts"]
}
